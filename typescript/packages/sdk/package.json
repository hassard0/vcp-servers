{
  "name": "@vcp/sdk",
  "version": "0.1.0",
  "description": "VCP lightweight client/SDK: canonical JSON, capability identity, manifest signing, plans, and the MCP bridge.",
  "license": "Apache-2.0",
  "homepage": "https://github.com/hassard0/vcp-servers/tree/main/typescript/packages/sdk#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/hassard0/vcp-servers.git",
    "directory": "typescript/packages/sdk"
  },
  "keywords": [
    "vcp",
    "verifiable-capability-protocol",
    "ai-agents",
    "authorization",
    "ed25519",
    "canonical-json",
    "jcs",
    "mcp"
  ],
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "development": "./src/index.ts",
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "node --conditions=development --experimental-strip-types --test \"test/*.test.ts\""
  }
}
