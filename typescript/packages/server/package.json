{
  "name": "@vcp/server",
  "version": "0.1.0",
  "description": "VCP-HTTP gateway server (Node http only) + sample capability provider + runnable §16 demo.",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./src/index.ts"
    }
  },
  "dependencies": {
    "@vcp/sdk": "0.1.0",
    "@vcp/gateway": "0.1.0"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "demo": "node --experimental-strip-types src/demo.ts",
    "test": "node --experimental-strip-types --test \"test/*.test.ts\""
  }
}
