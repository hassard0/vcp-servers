{
  "name": "@vcp/server",
  "version": "0.1.0",
  "description": "VCP-HTTP gateway server (Node http only) + sample capability provider + runnable §16 demo.",
  "license": "Apache-2.0",
  "homepage": "https://github.com/hassard0/vcp-servers/tree/main/typescript/packages/server#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/hassard0/vcp-servers.git",
    "directory": "typescript/packages/server"
  },
  "keywords": [
    "vcp",
    "verifiable-capability-protocol",
    "ai-agents",
    "authorization",
    "http",
    "gateway",
    "capability-provider"
  ],
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "development": "./src/index.ts",
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "dependencies": {
    "@vcp/sdk": "0.1.0",
    "@vcp/gateway": "0.1.0"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "demo": "node --conditions=development --experimental-strip-types src/demo.ts",
    "demo:obo": "node --conditions=development --experimental-strip-types src/demo-obo.ts",
    "test": "node --conditions=development --experimental-strip-types --test \"test/*.test.ts\""
  }
}
